# Persona: estudante/programador iniciante
# Contexto: conversor de temperatura
# Restrições: código simples, sem bibliotecas externas
# Formato: script interativo em Python

def celsius_para_fahrenheit(celsius):
    return (celsius * 9/5) + 32

def fahrenheit_para_celsius(fahrenheit):
    return (fahrenheit - 32) * 5/9

print("=== Conversor de Temperatura ===")
print("1 - Celsius → Fahrenheit")
print("2 - Fahrenheit → Celsius")

opcao = input("Escolha a opção (1 ou 2): ")

if opcao == "1":
    c = float(input("Digite a temperatura em Celsius: "))
    f = celsius_para_fahrenheit(c)
    print(f"{c}°C equivalem a {f:.2f}°F")
elif opcao == "2":
    f = float(input("Digite a temperatura em Fahrenheit: "))
    c = fahrenheit_para_celsius(f)
    print(f"{f}°F equivalem a {c:.2f}°C")
else:
    print("Opção inválida!")

